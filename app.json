{
  "expo": {
    "name": "Chaly",
    "slug": "app",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo2.png",
    "scheme": "cuitemap",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0A",
      "image": "./src/assets/images/black.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cuitemap.app",
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Chaly utilise votre position uniquement pendant la prise de photo pour afficher la localisation sur votre publication.",
        "NSLocationAlwaysUsageDescription": "Votre position est utilisée en arrière-plan pour améliorer votre expérience avec la carte de vos souvenirs.",
        "NSCameraUsageDescription": "Chaly utilise la caméra pour capturer une photo en temps réel que vous pouvez publier sur votre profil et partager avec vos amis.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./android/app/google-services.json",

      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.FLASHLIGHT",
        "android.permission.CAMERA"
      ],
      "package": "com.krdgs.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsDownloadToken": ""
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chaly accède à votre bibliothèque pour vous permettre de partager vos photos (si cette fonction est activée)."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Chaly utilise votre position pour afficher le lieu exact de vos publications sur la carte."
        }
      ],
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Chaly utilise la caméra pour prendre une photo que vous pouvez publier et partager avec vos amis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://cuitemap.com/api",
      "apiKey": "715b8006-63f4-482a-84fa-4c28f64f178c",
      "mapboxApiKey": "",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "dcc2e49e-4d2c-4bb7-bc44-705aaecc0c76"
      }
    },
    "owner": "cuitemap"
  }
}
