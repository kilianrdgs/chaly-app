{
	"extends": "./node_modules/expo/tsconfig.base",
	"compilerOptions": {
		"jsx": "react-jsx",
		"strict": true,
		"types": ["jest"],
		"jsxImportSource": "nativewind"
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts"
	],
	"exclude": ["node_modules"]
}
